# Toast POS API — template for local development.
# Copy this file to `.env` and fill in the real values.
# `.env` is gitignored; `.env.example` is safe to commit.

TOAST_API_HOSTNAME=https://ws-api.toasttab.com
TOAST_USER_ACCESS_TYPE=TOAST_MACHINE_CLIENT

TOAST_CLIENT_ID=your-client-id-here
TOAST_CLIENT_SECRET=your-client-secret-here

TOAST_LOCATION_ID=your-restaurant-id-here
