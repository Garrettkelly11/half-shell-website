# Firebase Functions params — non-secret values consumed by the deploy build.
#
# Copy this file to `functions/.env` and fill in the real values. The deploy
# bakes these into the function environment via the `defineString` params in
# `index.js`. The actual `.env` is gitignored (and excluded from the deploy
# source bundle) — Firebase reads it for values at deploy time, not as a file.
#
# Secrets (TOAST_CLIENT_SECRET) live in Google Secret Manager, set via:
#   firebase functions:secrets:set TOAST_CLIENT_SECRET
# Do NOT put the secret in this file.

TOAST_API_HOSTNAME=https://ws-api.toasttab.com
TOAST_USER_ACCESS_TYPE=TOAST_MACHINE_CLIENT
TOAST_CLIENT_ID=<your-toast-client-id>
TOAST_LOCATION_ID=<half-shell-restaurant-guid>
