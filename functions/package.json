{
  "name": "half-shell-functions",
  "description": "Cloud Functions for Half Shell's Toast POS sync.",
  "private": true,
  "engines": {
    "node": "20"
  },
  "main": "index.js",
  "dependencies": {
    "firebase-admin": "^12.0.0",
